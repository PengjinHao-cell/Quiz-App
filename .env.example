# 刷题通环境变量模板（复制为 .env 并填写）

# [必填] Flask 会话密钥（生产环境务必修改，用 openssl rand -hex 32 生成）
SECRET_KEY=你的随机密钥

# [必填] PostgreSQL 数据库连接
DATABASE_URL=postgresql://user:pass@host:5432/quizmaster

# [可选] 启动时自动创建管理员（设置后首次启动生效）
ADMIN_USERNAME=PuertoJupiter
ADMIN_PASSWORD=你的管理员密码

# [可选] 删除题库的验证密码
DELETE_PASSWORD=你的删除密码

# [可选] Resend API Key（用于发送注册验证码，推荐）
# 去 https://resend.com 注册免费账号获取，100封/天，无需信用卡
RESEND_API_KEY=re_你的API密钥

# [可选] DeepSeek API Key（用于 AI 粘贴文本解析）
DEEPSEEK_API_KEY=你的API密钥
